# OpenPoke Configuration
# Copy this file to .env and fill in your API keys

# Required: OpenRouter API key for LLM access
# Get your key from https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Required: Composio API key and Gmail auth config ID
# Get these from https://composio.dev/
COMPOSIO_API_KEY=your_composio_api_key_here
COMPOSIO_GMAIL_AUTH_CONFIG_ID=your_gmail_auth_config_id_here

# Optional: Google Calendar auth config ID (for the Calendar integration)
# Create a Google Calendar auth config in Composio and paste its ID here
# COMPOSIO_CALENDAR_AUTH_CONFIG_ID=your_calendar_auth_config_id_here

# Optional: LLM model selection (any OpenRouter model slug)
# Set one default for all agents. Free option for testing shown below;
# for production use e.g. anthropic/claude-sonnet-4
OPENPOKE_LLM_MODEL=openai/gpt-oss-20b:free
#
# Optional per-agent overrides (each falls back to OPENPOKE_LLM_MODEL):
# OPENPOKE_INTERACTION_MODEL=
# OPENPOKE_EXECUTION_MODEL=
# OPENPOKE_EXECUTION_SEARCH_MODEL=
# OPENPOKE_SUMMARIZER_MODEL=
# OPENPOKE_EMAIL_CLASSIFIER_MODEL=

# Optional: Server configuration
# OPENPOKE_HOST=0.0.0.0
# OPENPOKE_PORT=8001

# Optional: CORS configuration
# OPENPOKE_CORS_ALLOW_ORIGINS=*

# Optional: Documentation
# OPENPOKE_ENABLE_DOCS=1
# OPENPOKE_DOCS_URL=/docs
